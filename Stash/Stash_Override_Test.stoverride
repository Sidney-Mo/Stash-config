name: Stash Beta Override
category: Beta

dns: #!replace
  enable: true
  respect-rules: true
  ipv6: true
  prefer-h3: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16

  default-nameserver:
    - 8.8.8.8
    - 223.5.5.5
    - 119.29.29.29
    - system

  nameserver:
    - https://8.8.8.8/dns-query
    - https://1.1.1.1/dns-query
    - https://9.9.9.9/dns-query
    - https://dns.alidns.com/dns-query

  direct-nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query

  nameserver-policy:
    '+.t11-a.app': ['https://dns.alidns.com/dns-query', 'https://doh.pub/dns-query']
    'dns.cloudflare.com': [1.1.1.1, 1.0.0.1]
    'dns.google': [8.8.8.8, 8.8.4.4]
    'dns.quad9.net': [9.9.9.9, 149.112.112.112]
    'dns.alidns.com': [223.5.5.5, 223.6.6.6]
    'doh.pub': [1.12.12.12, 120.53.53.53]
    #WeChat
    '+.weixin.com': [https://dns.alidns.com/dns-query]
    '+.wechat.com': [https://dns.alidns.com/dns-query]
    '+.qq.com': [https://dns.alidns.com/dns-query]
    '+.tencent.com': [https://dns.alidns.com/dns-query]
    '+.qpic.cn': [https://dns.alidns.com/dns-query]
    '+.wx.qq.com': [https://dns.alidns.com/dns-query]
    '+.wxapp.qq.com': [https://dns.alidns.com/dns-query]
    #MeiTuan
    '+.meituan.com': [https://dns.alidns.com/dns-query]
    '+.meituan.net': [https://dns.alidns.com/dns-query]
    '+.sankuai.com': [https://dns.alidns.com/dns-query]
    '+.meituanwaimai.com': [https://dns.alidns.com/dns-query]
    '+.meituanzhongbao.com': [https://dns.alidns.com/dns-query]
    #KuGou
    '+.kugou.com': [https://dns.alidns.com/dns-query]
    '+.kugou.net': [https://dns.alidns.com/dns-query]
    '+.kgimg.com': [https://dns.alidns.com/dns-query]
    '+.kglink.cn': [https://dns.alidns.com/dns-query]
    '+.kugouaudio.com': [https://dns.alidns.com/dns-query]
    '+.kugoustore.com': [https://dns.alidns.com/dns-query]
    '+.kugouvoice.com': [https://dns.alidns.com/dns-query]
    '+.kugouyouth.com': [https://dns.alidns.com/dns-query]

  fallback:
    - https://dns.cloudflare.com/dns-query
    - https://dns.google/dns-query
    - https://dns.quad9.net/dns-query

  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4

  fake-ip-filter:
    - '*.lan'
    - '*.local'
    - 'localhost'
    - '*.msftconnecttest.com'
    - '*.msftncsi.com'
    - '*.msidentity.com'
    - 'captive.apple.com'
    - 'stun.*'
    - '+.stun.*.*'
    - '+.stun.*.*.*'
    - '+.stun.*.*.*.*'
    - '+.stun.*.*.*.*.*'
    - '+.weixin.com'
    - '+.wechat.com'
    - '+.qq.com'
    - '+.tencent.com'
    - 'speedtest.net'

profile: #!replace
  store-selected: true
  store-fake-ip: true


